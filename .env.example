# ── Alpaca Credentials ─────────────────────────────────────────────────────────
# Paper trading (safe to run without real money)
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_PAPER=true

# Set to "false" and provide live keys to go live
# ALPACA_PAPER=false
# ALPACA_API_KEY=AKXXXXXXXXXXXXXXXXXXXXXXXX
# ALPACA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Data Feed ──────────────────────────────────────────────────────────────────
# "iex"  = free, slight delay, sufficient for paper trading
# "sip"  = full NBBO feed, requires paid Alpaca subscription (use for live)
ALPACA_DATA_FEED=iex

# ── Trading Universe ───────────────────────────────────────────────────────────
SYMBOLS=SPY,QQQ,AAPL,NVDA,TSLA

# ── ORB Strategy Parameters ────────────────────────────────────────────────────
ORB_MINUTES=15             # Number of 1-min bars that define the opening range
RISK_RATIO=2.0             # TP = entry ± (ORB range * RISK_RATIO)
POSITION_SIZE_USD=1000.0   # USD value per trade (qty = floor(SIZE / close))
STOP_LOSS_TYPE=midpoint    # "midpoint" or "hard" (opposite range extreme)
MIN_BARS_REQUIRED=13       # Minimum bars to validate range (guards against gaps)

# ── Risk Management ────────────────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=2.0     # Flatten all + halt if daily loss exceeds this %

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=orb_trades.db      # SQLite file shared with dashboard.py

# ── Email Notifications ────────────────────────────────────────────────────────
# Uses Gmail SMTP. Requires a Gmail App Password (not your normal password).
# Enable at: myaccount.google.com/apppasswords  (2FA must be on)
EMAIL_SENDER=your.gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char app password (spaces OK)
EMAIL_RECIPIENT=sagi.elfassi@gmail.com
